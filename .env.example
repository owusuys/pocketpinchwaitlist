# ─────────────────────────────────────────────────────────────────────────────
# PocketPinch Waitlist — environment variables
# Copy this file to `.env.local` for local dev, and set the same vars in the
# Vercel dashboard (Project → Settings → Environment Variables) for production.
# The site renders and the form gives friendly errors even if these are unset.
# ─────────────────────────────────────────────────────────────────────────────

# The Google Apps Script Web App "/exec" URL that receives signups and writes
# them to your Google Sheet. See README.md → "Google Sheet + Apps Script setup".
# ⚠️ PLACEHOLDER — paste your deployed /exec URL here.
GOOGLE_APPS_SCRIPT_URL=

# Shared secret sent with every signup. MUST exactly match the `WAITLIST_SECRET`
# Script Property you set inside the Apps Script project. Use a long random string.
# ⚠️ PLACEHOLDER
WAITLIST_SHARED_SECRET=

# Resend API key for the confirmation email. Get one free at https://resend.com.
# ⚠️ PLACEHOLDER — if left blank, signups still work; the email is just skipped.
RESEND_API_KEY=

# The "From" address for the confirmation email. While testing you can use
# Resend's onboarding sender:  PocketPinch <onboarding@resend.dev>
# In production, verify your domain in Resend and use e.g. PocketPinch <hello@pocketpinch.app>
# ⚠️ PLACEHOLDER
RESEND_FROM_EMAIL=

# The public site URL, used for SEO / Open Graph absolute URLs.
# e.g. https://pocketpinch.app  (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
